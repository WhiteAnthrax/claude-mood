#!/usr/bin/env bash
# Helper for storing and retrieving spinner-verb mood presets in this repo.
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
REPO_DIR="$(dirname -- "$SCRIPT_DIR")"
MOODS_DIR="$REPO_DIR/moods"

usage() {
  echo "usage: mood-lib <sync|list|show|save|sanitize|apply|push|status> [args...]" >&2
  exit 1
}

# Shared jq defs for cleaning untrusted verb text (web-derived or pulled via
# git) before it reaches settings.json or the terminal.
# strip_cp drops C0/C1 controls (ANSI/OSC injection), bidi controls, line
# separators, invisible chars, TAG chars, and surrogates — but keeps
# ZWJ/ZWNJ/VS-16 so composed emoji survive. codepoint filtering via
# explode/implode avoids Oniguruma \u regex portability issues.
SANITIZE_JQ='
def strip_cp: explode | map(select(
    (. >= 32) and (. != 127)
    and ((. >= 128 and . <= 159) | not)
    and (IN(8206,8207,1564,8232,8233,8203,8288,65279,173) | not)
    and ((. >= 8234 and . <= 8238) | not)
    and ((. >= 8294 and . <= 8297) | not)
    and ((. >= 917504 and . <= 917631) | not)
    and ((. >= 55296 and . <= 57343) | not)
  )) | implode;
def wtrim: gsub("^[\\s　]+"; "") | gsub("[\\s　]+$"; "");
def sanitize_verbs:
  if length != 1 then error("expected exactly one JSON document")
  elif (.[0] | type) != "array" then error("verbs must be a JSON array of strings")
  elif (.[0] | all(type == "string") | not) then error("verbs must be a JSON array of strings")
  elif (.[0] | length) > 2000 then error("too many verbs (safety cap: 2000)")
  else .[0]
    | map(strip_cp | wtrim | .[0:1000])
    | map(select(length > 0))
    | reduce .[] as $v ([]; if index($v) then . else . + [$v] end)
  end
  | if length == 0 then error("no verbs left after sanitizing") else . end;
'

require_mode() {
  case "${1:-}" in
    replace|append) ;;
    *) echo "error: mode must be 'replace' or 'append'" >&2; exit 1 ;;
  esac
}

require_repo() {
  if [ ! -d "$REPO_DIR/.git" ]; then
    echo "error: $REPO_DIR is not a git repository" >&2
    exit 1
  fi
}

# Turns a free-form theme string into a safe filename component.
# Deny-list approach: strip path separators, control chars, and shell
# metacharacters, but keep non-ASCII (Japanese, etc.) text intact so
# slugs stay human-readable.
sanitize_slug() {
  local raw="$1" s
  s=$(printf '%s' "$raw" | tr -d '[:cntrl:]')
  s=$(printf '%s' "$s" | tr -d '/\\:*?"<>|`$;&(){}[]!^~'"'"'')
  s=$(printf '%s' "$s" | tr -s '[:space:]' '-')
  s=$(printf '%s' "$s" | sed -E 's/^[.-]+//; s/[.-]+$//')
  s=$(printf '%s' "$s" | cut -c1-40)
  if [ -z "$s" ]; then
    s="mood-$(date -u +%s)"
  fi
  printf '%s' "$s"
}

# Rejects slugs that could escape the moods/ directory (defensive check
# for slugs coming back from a caller rather than freshly generated here).
validate_slug() {
  local s="$1"
  case "$s" in
    ''|*/*|*'\'*) return 1 ;;
  esac
  return 0
}

cmd_sanitize() {
  local verbs_file="${1:-}"
  [ -n "$verbs_file" ] || usage
  if [ ! -f "$verbs_file" ]; then
    echo "error: verbs file not found: $verbs_file" >&2
    exit 1
  fi
  jq -e -s "$SANITIZE_JQ sanitize_verbs" "$verbs_file"
}

# Sanitizes verbs and writes them into settings.json's spinnerVerbs, leaving
# every other key untouched. On any failure settings.json is left as-is.
cmd_apply() {
  local mode="${1:-}" verbs_file="${2:-}"
  [ -n "$verbs_file" ] || usage
  require_mode "$mode"

  local settings settings_dir clean_tmp out_tmp
  settings=$(realpath -m "$HOME/.claude/settings.json")
  settings_dir=$(dirname "$settings")
  mkdir -p "$settings_dir" "$HOME/.claude/backups"
  [ -f "$settings" ] || printf '{}\n' > "$settings"

  clean_tmp=$(mktemp)
  out_tmp=$(mktemp -p "$settings_dir" settings.mood.XXXXXX)
  # trap fires at script exit, after locals are gone; :- keeps set -u happy
  trap 'rm -f "${clean_tmp:-}" "${out_tmp:-}"' EXIT

  cmd_sanitize "$verbs_file" > "$clean_tmp"
  cp "$settings" "$HOME/.claude/backups/settings.json.mood.$(date +%s)"

  jq --arg mode "$mode" --slurpfile v "$clean_tmp" \
    '.spinnerVerbs = {mode: $mode, verbs: $v[0]}' "$settings" > "$out_tmp"

  jq -e --slurpfile old "$settings" '
      (del(.spinnerVerbs) == ($old[0] | del(.spinnerVerbs)))
      and (.spinnerVerbs.verbs | length >= 1)' "$out_tmp" > /dev/null \
    || { echo "error: post-merge validation failed, settings.json unchanged" >&2; exit 1; }
  mv "$out_tmp" "$settings"
  echo "applied $(jq '.spinnerVerbs.verbs | length' "$settings") verbs (mode: $mode)"
}

cmd_sync() {
  require_repo
  git -C "$REPO_DIR" pull --ff-only
}

cmd_list() {
  shopt -s nullglob
  local files=("$MOODS_DIR"/*.json)
  if [ "${#files[@]}" -eq 0 ]; then
    echo "(no saved moods yet)"
    return 0
  fi
  {
    printf 'slug\ttheme\tmode\tverbs\tcreatedAt\n'
    for f in "${files[@]}"; do
      local slug
      slug=$(basename "$f" .json)
      # Files arrive via git pull, so treat their contents as untrusted:
      # strip control chars before they hit the terminal via @tsv.
      jq -r --arg slug "$slug" "$SANITIZE_JQ"'
        [$slug, (.theme | tostring | strip_cp), (.mode | tostring | strip_cp),
         (.verbs | length | tostring), (.createdAt | tostring | strip_cp)] | @tsv' \
        "$f" 2>/dev/null \
        || printf '%s\t(invalid)\t-\t-\t-\n' "$slug"
    done
  } | column -t -s $'\t'
}

cmd_show() {
  local slug="${1:-}"
  [ -n "$slug" ] || usage
  validate_slug "$slug" || { echo "error: invalid slug: $slug" >&2; exit 1; }
  local file="$MOODS_DIR/$slug.json"
  if [ ! -f "$file" ]; then
    echo "error: no such mood: $slug" >&2
    exit 1
  fi
  # Re-emit sanitized rather than cat'ing: the file came from git pull and
  # jq passes C1 control bytes through raw, so strip everything explicitly.
  jq -e "$SANITIZE_JQ"'
    {theme: (.theme | tostring | strip_cp | wtrim),
     mode:  (if .mode == "append" then "append" else "replace" end),
     verbs: ([.verbs] | sanitize_verbs)}' "$file" \
    || { echo "error: invalid mood file: $slug" >&2; exit 1; }
}

cmd_save() {
  local theme="${1:-}" mode="${2:-}" verbs_file="${3:-}"
  if [ -z "$theme" ] || [ -z "$mode" ] || [ -z "$verbs_file" ]; then
    usage
  fi
  require_mode "$mode"
  if [ ! -f "$verbs_file" ]; then
    echo "error: verbs file not found: $verbs_file" >&2
    exit 1
  fi
  require_repo
  mkdir -p "$MOODS_DIR"

  # Clean the verbs before they are committed to the shared repo, and the
  # theme before it lands in the JSON and the commit message.
  local clean_tmp
  clean_tmp=$(mktemp)
  trap 'rm -f "${clean_tmp:-}"' EXIT
  cmd_sanitize "$verbs_file" > "$clean_tmp"
  theme=$(jq -rn --arg t "$theme" "$SANITIZE_JQ"' $t | strip_cp | wtrim')
  if [ -z "$theme" ]; then
    theme="mood-$(date -u +%s)"
  fi

  local base_slug slug i
  base_slug=$(sanitize_slug "$theme")
  slug="$base_slug"
  i=2
  while [ -e "$MOODS_DIR/$slug.json" ]; do
    slug="${base_slug}-${i}"
    i=$((i + 1))
  done

  local created_at
  created_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  jq -n \
    --arg theme "$theme" \
    --arg mode "$mode" \
    --arg createdAt "$created_at" \
    --slurpfile verbs "$clean_tmp" \
    '{theme: $theme, mode: $mode, verbs: $verbs[0], createdAt: $createdAt}' \
    > "$MOODS_DIR/$slug.json"

  git -C "$REPO_DIR" add "moods/$slug.json"
  git -C "$REPO_DIR" commit --quiet -m "Add mood: $theme"

  printf '%s\n' "$slug"
}

cmd_status() {
  require_repo
  local ahead
  ahead=$(git -C "$REPO_DIR" rev-list --count '@{u}..HEAD' 2>/dev/null || echo "?")
  if [ "$ahead" = "0" ]; then
    echo "up to date, nothing to push"
  else
    echo "$ahead unpushed commit(s)"
  fi
}

cmd_push() {
  require_repo
  if git -C "$REPO_DIR" push; then
    return 0
  fi
  echo "push rejected, retrying after rebase..." >&2
  if git -C "$REPO_DIR" pull --rebase --autostash && git -C "$REPO_DIR" push; then
    echo "pushed after rebase"
    return 0
  fi
  echo "error: could not push automatically — run 'mood-lib sync' and resolve manually" >&2
  exit 1
}

main() {
  local sub="${1:-}"
  [ -n "$sub" ] || usage
  shift
  case "$sub" in
    sync) cmd_sync "$@" ;;
    list) cmd_list "$@" ;;
    show) cmd_show "$@" ;;
    save) cmd_save "$@" ;;
    sanitize) cmd_sanitize "$@" ;;
    apply) cmd_apply "$@" ;;
    push) cmd_push "$@" ;;
    status) cmd_status "$@" ;;
    *) usage ;;
  esac
}

main "$@"
